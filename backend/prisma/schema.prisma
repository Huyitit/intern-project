generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model users {
  id              Int       @id @default(autoincrement())
  full_name       String
  username        String    @unique
  password        String
  hashed_password String
  role            String
  phone           String?
  email           String?   @unique
  create_at       DateTime  @default(now())
  update_at       DateTime?
  avatar_url      String?
}
